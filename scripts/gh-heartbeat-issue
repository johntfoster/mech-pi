#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=/dev/null
source "$ROOT_DIR/lib/agent_issue_workflow.sh"
agent_require_tools

AGENT_ISSUE_NUMBER=
AGENT_TTL_SECONDS=${DEFAULT_TTL_SECONDS}
run_id=
notes='Heartbeat'

while [[ $# -gt 0 ]]; do
  case "$1" in
    --issue|--issue-number)
      AGENT_ISSUE_NUMBER=${2:-}; shift 2 ;;
    --run-id)
      run_id=${2:-}; shift 2 ;;
    --ttl-seconds)
      AGENT_TTL_SECONDS=${2:-}; shift 2 ;;
    --notes)
      notes=${2:-}; shift 2 ;;
    --*)
      agent_fail "Unknown option: $1" 2 '{}' ;;
    *)
      if [[ -z "$AGENT_ISSUE_NUMBER" ]]; then AGENT_ISSUE_NUMBER=$1; shift; else agent_fail "Unexpected argument: $1" 2 '{}'; fi ;;
  esac
done
export AGENT_ISSUE_NUMBER AGENT_TTL_SECONDS

[[ -n "$run_id" ]] || agent_fail 'run-id is required.' 2 '{}'
repo=$(agent_repo)
issue_number=$(agent_issue_number)
ttl_seconds=$(agent_ttl_seconds)
agent_id=$(agent_identity_id)
agent_label=$(agent_identity_label)

issue=$(agent_fetch_issue "$repo" "$issue_number")
[[ $(jq -r '.state // empty' <<<"$issue") == 'open' ]] || agent_fail 'Issue is closed.' 4 "{\"issue\":$issue_number}"
comments=$(agent_fetch_comments "$repo" "$issue_number")
events=$(agent_collect_events <<<"$comments")
winning_claim=$(jq -c --arg now "$(agent_now)" '
  def is_terminal: (.type // "") as $t | ($t == "release" or $t == "blocked" or $t == "completed" or $t == "superseded");
  reduce .[] as $event ({claims:{}, terminals:{}};
    ($event.run_id // "") as $run
    | if $run == "" then .
      elif ($event.type // "") == "claim" then .claims[$run] = $event
      elif ($event.type // "") == "heartbeat" and (.claims[$run] != null) then .claims[$run] = (.claims[$run] + {lease_expires_at: ($event.lease_expires_at // .claims[$run].lease_expires_at), last_event: $event})
      elif ($event | is_terminal) then .terminals[$run] = true
      else . end)
  | [(.claims | to_entries[]) | select(.key as $run | (.terminals[$run] // false) | not) | .value]
  | map(select((.lease_expires_at // "") > $now))
  | sort_by(.claimed_at // "", ._comment_id // 0)
  | if length == 0 then null else .[0] end
' <<<"$events")
[[ $(jq -r '.run_id // empty' <<<"$winning_claim") == "$run_id" ]] || agent_fail 'No active matching claim for heartbeat.' 5 "{\"issue\":$issue_number,\"run_id\":$(jq -Rn --arg v "$run_id" '$v')}"

heartbeat_at=$(agent_now)
lease_expires_at=$(agent_add_seconds "$heartbeat_at" "$ttl_seconds")
payload=$(jq -n --arg repo "$repo" --argjson issue "$issue_number" --arg agent_id "$agent_id" --arg agent_label "$agent_label" --arg run_id "$run_id" --arg heartbeat_at "$heartbeat_at" --arg lease_expires_at "$lease_expires_at" --arg notes "$notes" '{version:1,type:"heartbeat",repo:$repo,issue:$issue,agent_id:$agent_id,agent_label:$agent_label,run_id:$run_id,heartbeat_at:$heartbeat_at,lease_expires_at:$lease_expires_at,status:"active",notes:$notes}')
comment=$(agent_post_comment "$repo" "$issue_number" "$(agent_json_block "$payload")")

jq -n --argjson issue "$issue_number" --arg run_id "$run_id" --argjson comment_id "$(jq -r '.id // 0' <<<"$comment")" --arg heartbeat_at "$heartbeat_at" --arg lease_expires_at "$lease_expires_at" '{ok:true,issue:$issue,run_id:$run_id,comment_id:$comment_id,heartbeat_at:$heartbeat_at,lease_expires_at:$lease_expires_at}'
